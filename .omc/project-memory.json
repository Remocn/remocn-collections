  "build": {
    "buildCommand": "cd /Users/dev_wandry/projects/opensource/remocn-demo; npx tsc --noEmit -p tsconfig.json 2>&1 | grep -i \"sponsor-ln\" || echo \"NO ERRORS in sponsor-ln\"; mkdir -p scratch-out\nnpx remotionb still src/remotion/index.ts sponsor-ln scratch-out/a.png --frame=120 2>&1 | tail -1\nnpx remotionb still src/remotion/index.ts sponsor-ln scratch-out/b.png --frame=142 2>&1 | tail -1\nnpx remotionb still src/remotion/index.ts sponsor-ln scratch-out/c.png --frame=190 2>&1 | tail -1\nnode -e '\nconst sharp=require(\"sharp\");\n(async()=>{const{data,info}=await sharp(\"scratch-out/c.png\").raw().toBuffer({resolveWithObject:true});\nconst W=info.width,ch=info.channels,rowY=350;const cb=new Array(W).fill(0);\nfor(let y=rowY-45;y<=rowY+45;y++)for(let x=0;x<W;x++){const i=(y*W+x)*ch;const b=(data[i]+data[i+1]+data[i+2])/3;if(b>cb[x])cb[x]=b;}\nconst TH=150;let rr=0;for(let x=200;x<620;x++)if(cb[x]>TH)rr=x;\nlet cl=W,cr=0;for(let x=625;x<758;x++)if(cb[x]>90){if(x<cl)cl=x;cr=x;}\nlet al=W;for(let x=700;x<1000;x++)if(cb[x]>TH){al=x;break;}\nconst cc=Math.round((cl+cr)/2);\nconsole.log(JSON.stringify({remocnRight:rr,crossCenter:cc,avatarLeft:al,gapLeft:cc-rr,gapRight:al-cc}));})();\n'",
